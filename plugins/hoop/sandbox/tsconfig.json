{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@/*": ["./*"],
      "@shared/*": ["../shared/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["**/*.ts", "../shared/*.ts"],
  "exclude": ["node_modules", "dist", "../shared/**/*.test.ts"]
}
