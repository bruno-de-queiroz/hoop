{
  "name": "hoop-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Local web dashboard for the hoop plugin. Talks to agent-sandbox over a Unix domain socket; carries no claude state itself.",
  "scripts": {
    "dev": "next dev -p ${HOOP_PORT:-7842}",
    "build": "next build",
    "start": "next start -p ${HOOP_PORT:-7842}",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
